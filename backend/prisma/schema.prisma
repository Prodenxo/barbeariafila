generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Barbeiro {
  id                String    @id @default(uuid())
  name              String
  phone             String    @unique
  evolutionInstance String    @unique
  token             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  servicos          Servico[]
  fila              Fila[]
}

model Cliente {
  id        String   @id @default(uuid())
  name      String
  phone     String   @unique // Telefone sem o @s.whatsapp.net
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  fila      Fila[]
}

model Servico {
  id        String   @id @default(uuid())
  name      String
  price     Float
  duration  Int
  barbeiro  Barbeiro @relation(fields: [barbeiroId], references: [id])
  barbeiroId String
  fila      Fila[]
}

enum StatusFila {
  AGUARDANDO
  EM_ATENDIMENTO
  FINALIZADO
  CANCELADO
}

model Fila {
  id            String     @id @default(uuid())
  position      Int
  status        StatusFila @default(AGUARDANDO)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  
  barbeiro      Barbeiro   @relation(fields: [barbeiroId], references: [id])
  barbeiroId    String
  
  servico       Servico    @relation(fields: [servicoId], references: [id])
  servicoId     String

  cliente       Cliente    @relation(fields: [clienteId], references: [id])
  clienteId     String
}
